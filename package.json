{
  "name": "onboarding-tools",
  "version": "0.1.0",
  "description": "Declarative unlockable onboarding, progressive disclosure, and tutorial overlays for React apps. Zero runtime dependencies, framework-agnostic.",
  "type": "module",
  "author": "Carlos <57185359+CMolG@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/CMolG/onboarding-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CMolG/onboarding-tools.git"
  },
  "bugs": {
    "url": "https://github.com/CMolG/onboarding-tools/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && node -e \"import('node:fs').then(fs => fs.copyFileSync('src/styles.css', 'dist/styles.css'))\"",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "7.3.2",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "onboarding",
    "progressive-disclosure",
    "tutorial",
    "react",
    "unlockable",
    "product-tour",
    "feature-flags",
    "personalization",
    "archetype",
    "tutorial-overlay",
    "spotlight",
    "coachmark",
    "user-onboarding",
    "zero-deps",
    "typescript"
  ]
}
